{
  "AppSettings": {
    "BaseUrl": "",
    "FrontEndUrl": "https://bekam-tau.vercel.app"
  },
  "ConnectionStrings": {    
    "AppConnection": "",
    "IdentityConnection": "",
    "HangfireConnection": "",
    "Redis": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/prod-log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true,
          "shared": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] ({CorrelationId}) {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ]

  },
  "Jwt": {
    "Key": "",
    "Issuer": "Bekam.Auth",
    "Audience": "Bekam.API",
    "ExpiryMinutes": 15
  },
  "MailSettings": {
    "Mail": "",
    "DisplayName": "Bekam",
    "Password": "",
    "Host": "smtp.gmail.com",
    "Port": 587
  },
  "Redis": {
    "TimeToLiveInDays": 7
  },
  "StripeSettings": {
    "PublishableKey": "",
    "SecretKey": "",
    "WhSecret": ""
  },
  "AllowedHosts": "*"

}
