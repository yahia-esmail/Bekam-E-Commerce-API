{
  "AppSettings": {
    //"BaseUrl": "https://localhost:7262",
    "BaseUrl": "",
    "FrontEndUrl": ""
  },
  "ConnectionStrings": {
    "AppConnection": "Server=.;Database=BekamDb;User Id=sa;Password=123456;TrustServerCertificate=True;",
    "IdentityConnection": "Server=.;Database=BekamIdentityDb;User Id=sa;Password=123456;TrustServerCertificate=True;",
    "HangfireConnection": "Server=.;Database=BekamJobs;User Id=sa;Password=123456;TrustServerCertificate=True;",
    "Redis": "localhost"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],

    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "System": "Warning"
      }
    },

    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithCorrelationId"
    ],

    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/dev-log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 10,
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] ({CorrelationId}) {Message:lj}{NewLine}{Exception}"
        }
      }
    ],

    "Properties": {
      "Application": "Bekam.API"
    }
  }

}
